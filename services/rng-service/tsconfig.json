{
    "include":  [
                    "src/**/*"
                ],
    "compilerOptions":  {
                            "forceConsistentCasingInFileNames":  true,
                            "outDir":  "./dist",
                            "lib":  [
                                        "ES2020"
                                    ],
                            "resolveJsonModule":  true,
                            "declaration":  true,
                            "strict":  true,
                            "target":  "ES2020",
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "module":  "commonjs",
                            "rootDir":  "./src"
                        }
}
